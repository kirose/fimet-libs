<?xml version="1.0" encoding="UTF-8"?>
<fimet>
	<!-- The path to FIMET data base -->
	<databases>
		<database name="fimet" path="resources/fimet.db" creator="com.fimet.sqlite.FimetCreator" />
		<database name="store-codes" path="store/codes.db" creator="com.fimet.sqlite.CodeStoreCreator"/>
	</databases>
	<!-- The application properties -->
	<properties>
		<!-- The CompilerManager will use this path to get the SystemJavaCompiler -->
		<property name="java.home" value="C:\Program Files\Java\jdk1.8.0_91\jre"/>
		<property name="simulator.numberOfThreads" value="5"/>
		<!-- If true all Simulator Models will be compiled at startup -->
		<property name="simulator.recompileModelsAtStartup" value="true"/>
		<!-- The max execution time in milliseconds -->
		<property name="usecase.maxExecutionTime" value="9000"/>
		<!-- EAGER or LAZY -->
		<property name="fieldGroup.mode" value="EAGER"/>
	</properties>
	<!-- You can declare a new manager or override an existent -->
	<managers>
		<manager name="com.fimet.ISQLiteManager" class="com.fimet.sqlite.SQLiteManager" />
		<manager name="com.fimet.client.IClientManager" class="com.fimet.client.ClientManager" autostart="true"/>
		<manager name="com.fimet.ICommandManager" class="com.fimet.cmd.CommandManager"/>
		<manager name="com.fimet.IExecutorManager" class="com.fimet.exe.ExecutorManager"/>
		<manager name="com.fimet.ISessionManager" class="com.fimet.usecase.SessionManager"/>
		<manager name="com.fimet.ISocketManager" class="com.fimet.socket.SocketManager"/>
		<manager name="com.fimet.ISimulatorModelManager" class="com.fimet.simulator.SimulatorModelManager"/>
		<manager name="com.fimet.ISimulatorManager" class="com.fimet.simulator.SimulatorManager"/>
	</managers>
	<!-- You can extend a extension-point for a custom functionality -->
	<extensions>
		<extension name="com.fimet.usecase.IUseCaseStore" class="com.fimet.cmd.UseCaseStore" />
		<extension name="com.fimet.stress.IStressStore" class="com.fimet.cmd.StressStore" />
		<extension name="com.fimet.dao.IParserDAO" class="com.fimet.sqlite.dao.ParserDAO" />
		<extension name="com.fimet.dao.IFieldGroupDAO" class="com.fimet.sqlite.dao.FieldGroupDAO" />
		<extension name="com.fimet.dao.IFieldFormatDAO" class="com.fimet.sqlite.dao.FieldFormatDAO" />
		<extension name="com.fimet.dao.ISimulatorModelDAO" class="com.fimet.sqlite.dao.SimulatorModelDAO" />
		<extension name="com.fimet.dao.ISimulatorMessageDAO" class="com.fimet.sqlite.dao.SimulatorMessageDAO" />
	</extensions>
</fimet>