package com.fimet.core.iso8583;

import com.fimet.core.iso8583.parser.Message;
import com.fimet.core.net.ISocket;

public class ISOTestBuilder {
	ISocket iSocket;
	Message message;
	public ISOTestBuilder(ISocket socket) {
		iSocket = socket;
		message = new Message();
	}
	ISOTestBuilder message(Message message) {
		this.message = message;
		return this;
	}
	ISOTestBuilder addValue(String idField, String value) {
		this.message.setValue(idField, value);
		return this;
	}
	ISOTestBuilder removeValue(String idField) {
		this.message.remove(idField);
		return this;
	}
	ISOTestBuilder run() {
		return this;
	}
}
