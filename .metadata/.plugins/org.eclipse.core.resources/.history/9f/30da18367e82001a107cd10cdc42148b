package com.fimet.core.usecase.exe;

import com.fimet.core.IExecutorManager;
import com.fimet.core.usecase.sync.SyncExecutor;

public class ExecutorManager implements IExecutorManager {

	private IExecutor syncExecutor;
	private IExecutor asyncExecutor;
	public ExecutorManager() {
		syncExecutor = new SyncExecutor();
		syncExecutor.startExecutor();
		asyncExecutor = null;
	}
	
	@Override
	public IExecutor getSyncExecutor() {
		return syncExecutor;
	}

	@Override
	public IExecutor getAsyncExecutor() {
		return asyncExecutor;
	}

	@Override
	public void free() {
	}

	@Override
	public void saveState() {
	}

}
