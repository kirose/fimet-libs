package com.fimet.core.persistence.impl;

import java.io.File;
import java.io.IOException;
import java.sql.SQLException;
import java.util.HashMap;
import java.util.Map;

import com.fimet.commons.console.Console;
import com.fimet.commons.exception.PersistenceException;
import com.fimet.core.Activator;
import com.fimet.core.Manager;
import com.fimet.core.persistence.ISQLiteManager;
import com.fimet.core.xml.FimetXml;
import com.j256.ormlite.jdbc.JdbcConnectionSource;
import com.j256.ormlite.support.ConnectionSource;

/**
 * 
 * @author Marco A. Salazar
 * @email marcoasb99@ciencias.unam.mx
 *
 */
public final class SQLiteManager implements ISQLiteManager {
	/*static {
		DataBaseManager.getInstanceSilently();
	}*/
	public static final String DB_FIMET = "fimet";
	
	private static SQLiteManager instance;
	private Map<String,ConnectionSource> connections;

	public static SQLiteManager getInstance() {
		if (instance == null) {
			instance = new SQLiteManager();
		}
		return instance;
	}
	public SQLiteManager() {
		this.connections = new HashMap<String,ConnectionSource>();
		loadSources();
		createDataBaseIfNotExists();
		connect();
	}
	public ConnectionSource getConnection(String name) {
		return connections.get(name);
	}
    public ConnectionSource getFimetConnection() {
		return connections.get(DB_FIMET);
	}
    private ConnectionSource newConnection(String name) throws SQLException {
    	return new JdbcConnectionSource("jdbc:sqlite:resources/"+name+".db");
    }
    private void createDataBaseIfNotExists() {
    	File fileDataBase = new File("resources/"+DB_FIMET+".db");
    	if (!fileDataBase.exists()) {
			try {
				fileDataBase.createNewFile();
				ConnectionSource connection = newConnection(DB_FIMET);
				new SQLiteCreatorDefault().create(connection);
			} catch (Exception e) {
				Console.getInstance().debug(SQLiteManager.class,"Error creating database "+DB_FIMET+".db");
			}
    	}
    }
	public void connect() {
		if (connections != null && !connections.isEmpty()) {
			for (Map.Entry<String, ConnectionSource> e : connections.entrySet()) {
		    	try {
		    		ConnectionSource connection = newConnection(e.getKey());
		    		connections.put(e.getKey(), connection);
					Console.getInstance().debug(SQLiteManager.class,"Connected to database "+DB_FIMET+".db");
				} catch (SQLException ex) {
					disconnect();
				}
			}
		}
	}
	public void disconnect() {
		if (connections != null && !connections.isEmpty()) {
			for (Map.Entry<String, ConnectionSource> e : connections.entrySet()) {
				if (e.getValue() != null) {
					try {
						e.getValue().close();
					} catch (IOException ex) {
						FimetLogger.error("Cannot create Connection to "+DB_FIMET, ex);
						throw new PersistenceException(ex);
					}
				}
			}
			connections.clear();
		}
	}
	@Override
	public void free() {}
	@Override
	public void saveState() {
		
	}
	@Override
	public String toString() {
		StringBuilder s = new StringBuilder();
		if (connections != null && !connections.isEmpty()) {
			for (Map.Entry<String, ConnectionSource> e : connections.entrySet()) {
				s.append(e.getKey()).append(",");
			}
		}
		return s.toString();
	}
	private void loadSources() {
		FimetXml cfg = Manager.getCfg();
		if (cfg != null && cfg.getSource() != null) {
			connections.put(cfg.getSource().getName(), null);
		}
	}
}
