package com.fimet.core.stress;

import java.io.File;
import java.util.ArrayList;
import java.util.List;

import com.fimet.core.net.ISocket;
import com.fimet.core.stress.exe.StressExecutor;

public class TestBuilder {
	private List<StressSocket> stressSockets;
	private List<ISocket> connections;
	public TestBuilder() {
		stressSockets = new ArrayList<>();
		connections = new ArrayList<>();
	}
	public TestBuilder add(ISocket socket, File stressFile) {
		connections.add(socket);
		stressSockets.add(new StressSocket(socket, stressFile));
		return this;
	}
	public void execute() {
		Stress stress = new Stress();
		stress.setConnections(connections);
		stress.setStressSockets(stressSockets);
		new StressExecutor(stress).execute();
	}
}
