import com.fimet.core.net.ISocket;

public class ISOTestBuilder implements IMessengerListener {
	private static IMessengerManager messengerManager = Manager.get(IMessengerManager.class);
	IMessenger messenger;
	Message message;
	public ISOTestBuilder(ISocket socket) {
		message = new Message();
		message.setParser(socket.getParser());
		messenger = messengerManager.getMessenger(socket);
		messenger.setListener(this);
	}
	ISOTestBuilder message(Message message) {
		this.message = message;
		return this;
	}
	ISOTestBuilder setValue(String idField, String value) {
		this.message.setValue(idField, value);
		return this;
	}
	ISOTestBuilder removeValue(String idField) {
		this.message.remove(idField);
		return this;
	}
	ISOTestBuilder run() {
		messenger.connect();
		messenger.writeMessage(message);
		return this;
	}
