package com.fimet.core.usecase.exe;

import java.util.LinkedHashMap;
import java.util.Map;

import com.fimet.core.net.ISocket;

public class ExecutionResult {
	private ExecutionStatus status;
	private Map<ISocket, SocketResult> path;
	public ExecutionResult() {
		this.path = new LinkedHashMap<ISocket, SocketResult>();
	}
	public ExecutionStatus getStatus() {
		return status;
	}
	public void setStatus(ExecutionStatus status) {
		this.status = status;
	}
	public SocketResult getOrPutSocketData(ISocket socket) {
		if (!path.containsKey(socket)) {
			path.put(socket, new SocketResult());
		}
		return path.get(socket);
	}
	public SocketResult getSocketData(ISocket socket) {
		return path.get(socket);
	}
}
