package com.fimet.core.usecase;

import java.util.ArrayList;
import java.util.List;

import com.fimet.core.iso8583.parser.Message;
import com.fimet.core.net.ISocket;
import com.fimet.core.validator.IValidator;
import com.fimet.core.validator.NullValidator;

public class UseCase implements IUseCase {
	private int maxExecutionTime;
	private String name;
	private Message message;
	private List<ISocket> connections;
	private IValidator validator;
	public UseCase() {
		this.validator = NullValidator.INSTANCE;
		this.connections = new ArrayList<>();
		this.maxExecutionTime = 5000;
	}
	@Override
	public String getName() {
		return name;
	}
	@Override
	public Message getMessage() {
		return message;
	}
	@Override
	public ISocket getAcquirer() {
		return connections != null && !connections.isEmpty() ? connections.get(0) : null;
	}
	@Override
	public List<ISocket> getConnections() {
		return connections;
	}
	@Override
	public int getMaxExecutionTime() {
		return maxExecutionTime;
	}
	@Override
	public IValidator getValidator() {
		return validator;
	}
	public void setMaxExecutionTime(int maxExecutionTime) {
		this.maxExecutionTime = maxExecutionTime;
	}
	public void setName(String name) {
		this.name = name;
	}
	public void setMessage(Message message) {
		this.message = message;
	}
	public void addConnection(ISocket socket) {
		connections.add(socket);
	}
	public void setConnections(List<ISocket> connections) {
		this.connections = connections;
	}
	public void setValidator(IValidator validator) {
		this.validator = validator;
	}
	public void setExecutionTime(int maxExecutionTime) {
		this.maxExecutionTime = maxExecutionTime;
	}
}
