package com.fimet.net;

import java.io.IOException;
import java.net.Socket;

import com.fimet.core.net.IAdaptedSocketListener;
import com.fimet.core.net.ISocket;

/**
 * @author Marco A. Salazar
 * @email marcoasb99@ciencias.unam.mx
 *
 */
public class AdaptedSocketClient extends AdaptedSocket {

	public AdaptedSocketClient(ISocket iSocket, IAdaptedSocketListener listener) {
		super(iSocket, listener);
	}
	@Override
	protected Socket newSocket() throws IOException {
		return socket = new Socket(iSocket.getAddress(), iSocket.getPort());
	}
	@Override
	void close() {
		if (socket != null)  {
			try {
				socket.close();
			} catch (Throwable e) {/*Activator.getInstance().warning("socket.close()", e);*/}
			socket = null;
		}
	}
}
