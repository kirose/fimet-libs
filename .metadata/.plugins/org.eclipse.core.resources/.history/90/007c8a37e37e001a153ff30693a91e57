package com.fimet.core.iso8583;

import com.fimet.commons.FimetLogger;
import com.fimet.core.IMessengerManager;
import com.fimet.core.Manager;
import com.fimet.core.iso8583.parser.Message;
import com.fimet.core.net.IMessenger;
import com.fimet.core.net.IMessengerListener;
import com.fimet.core.net.ISocket;

public class TestBuilder implements IMessengerListener {
	private static IMessengerManager messengerManager = Manager.get(IMessengerManager.class);
	private static IValidator NULL_VALIDATOR = new NullValidator();
	IMessenger messenger;
	Message message;
	IValidator validator;
	public TestBuilder(ISocket socket) {
		message = new Message();
		message.setParser(socket.getParser());
		messenger = messengerManager.getMessenger(socket);
		messenger.setListener(this);
		validator = NULL_VALIDATOR;
	}
	TestBuilder message(Message message) {
		this.message = message;
		return this;
	}
	TestBuilder setValue(int idField, String value) {
		this.message.setValue(idField, value);
		return this;
	}
	TestBuilder removeValue(int idField) {
		this.message.remove(idField);
		return this;
	}
	TestBuilder setValue(String idField, String value) {
		this.message.setValue(idField, value);
		return this;
	}
	TestBuilder removeValue(String idField) {
		this.message.remove(idField);
		return this;
	}
	TestBuilder setValidator(IValidator validator) {
		this.validator = validator != null ? validator : NULL_VALIDATOR;
		return this;
	}
	TestBuilder run() {
		if (messenger.isConnected()) {
			messenger.writeMessage(message);
		} else {
			messenger.connect();
		}
		return this;
	}
	@Override
	public void onMessengerConnected(IMessenger messenger) {
		messenger.writeMessage(message);
	}
	@Override
	public void onMessengerConnecting(IMessenger messenger) {
		// TODO Auto-generated method stub
		
	}
	@Override
	public void onMessengerDisconnected(IMessenger messenger) {
		// TODO Auto-generated method stub
		
	}
	@Override
	public void onMessengerWriteMessage(IMessenger messenger, byte[] message) {
		// TODO Auto-generated method stub
		
	}
	@Override
	public void onMessengerReadMessage(IMessenger messenger, byte[] message) {
		// TODO Auto-generated method stub
		
	}
	@Override
	public void onMessengerParseMessage(IMessenger messenger, Message message) {
		// TODO Auto-generated method stub
		
	}
	@Override
	public void onMessengerSimulateResponse(IMessenger messenger, Message response) {
		// TODO Auto-generated method stub
		
	}
	@Override
	public void onMessengerSimulateRequest(IMessenger messenger, Message request) {
		try {
			validator.onRequest(messenger.getConnection(), request);
		} catch (Throwable e) {
			FimetLogger.error("Simulate Request "+this, e);
		}
	}
}
