package com.fimet.core.stress.exe;

import java.sql.Timestamp;
import java.util.ArrayList;
import java.util.HashSet;
import java.util.List;
import java.util.Set;

import com.fimet.core.IMessengerManager;
import com.fimet.core.Manager;
import com.fimet.core.iso8583.parser.Message;
import com.fimet.core.net.IAdaptedSocket;
import com.fimet.core.net.IMessenger;
import com.fimet.core.net.IMessengerListener;
import com.fimet.core.net.ISocket;
import com.fimet.core.stress.IInjector;
import com.fimet.core.stress.IInjectorListener;
import com.fimet.core.stress.IStress;
import com.fimet.core.stress.StressInjector;

public class StressExecutor implements IMessengerListener, IInjectorListener {
	private IMessengerManager messengerManager = Manager.get(IMessengerManager.class);
	private Connector connector;
	private IStress stress;
	private List<StressInjector> injectors;
	public StressExecutor(IStress stress) {
		this.injectors = new ArrayList<>();
		this.stress = stress;
	}
	public void execute() {
		connector = new Connector(stress);
		connector.start();
	}
	public void _execute() {
		for (StressInjector i : injectors) {
			i.startInjector();
		}
	}
	private class Connector extends Thread {
		IStress stress;
		Set<ISocket> toConnect = new HashSet<ISocket>();
		public Connector(IStress stress) {
			this.stress = stress;
			this.toConnect.addAll(stress.getConnections());
		}
		synchronized public void onConnected(ISocket socket) {
			toConnect.remove(socket);
			IAdaptedSocket adaptedSocket = messengerManager.getMessenger(socket).getSocket();
			if (stress.getStressFile(socket) != null) {
				StressInjector injector = new StressInjector(adaptedSocket, stress.getStressFile(socket));
				injector.setListener(StressExecutor.this);
				injectors.add(injector);
			}
			if(toConnect.isEmpty()) {
				StressExecutor.this._execute();
			}
		}
		public void run() {
			for (ISocket iSocket : stress.getConnections()) {
				IMessenger messenger = messengerManager.getMessenger(iSocket);
				messenger.setListener(StressExecutor.this);
				if (messenger.isDisconnected()) {
					messenger.connect();
				} else if (messenger.isConnected()) {
					onConnected(messenger.getConnection());
				}
			}
		}
	}
	@Override
	public void onMessengerConnected(IMessenger messenger) {
		connector.onConnected(messenger.getConnection());
	}
	@Override
	public void onMessengerConnecting(IMessenger messenger) {}
	@Override
	public void onMessengerDisconnected(IMessenger messenger) {}
	@Override
	public void onMessengerWriteToSocket(IMessenger messenger, byte[] message) {}
	@Override
	public void onMessengerWriteMessage(IMessenger messenger, Message message) {}
	@Override
	public void onMessengerReadFromSocket(IMessenger messenger, byte[] message) {}
	@Override
	public void onMessengerReadMessage(IMessenger messenger, Message message) {}
	@Override
	synchronized public void onInjectorStartInject(IInjector injector) {
		System.out.println("Start "+injector+" at "+new Timestamp(System.currentTimeMillis()));
	}
	@Override
	synchronized public void onInjectorFinishInject(IInjector injector) {
		System.out.println("Finish "+injector+" at "+new Timestamp(System.currentTimeMillis()));
	}
}
