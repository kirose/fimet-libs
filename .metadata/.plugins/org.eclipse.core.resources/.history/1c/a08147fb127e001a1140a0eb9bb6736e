package com.fimet.test;

import com.fimet.core.IParserManager;
import com.fimet.core.ISimulatorManager;
import com.fimet.core.IUseCaseExecutorManager;
import com.fimet.core.Manager;
import com.fimet.core.iso8583.adapter.IAdapterManager;
import com.fimet.core.iso8583.parser.IParser;
import com.fimet.core.iso8583.parser.Message;
import com.fimet.core.net.Socket;
import com.fimet.core.simulator.ISimulator;
import com.fimet.usecase.NullValidator;
import com.fimet.usecase.UseCase;

import junit.framework.Test;
import junit.framework.TestCase;
import junit.framework.TestSuite;

/**
 * Unit test for simple App.
 */
public class UseCaseTest 
    extends TestCase
{
    /**
     * Create the test case
     *
     * @param testName name of the test case
     */
    public UseCaseTest( String testName )
    {
        super( testName );
    }

    /**
     * @return the suite of tests being tested
     */
    public static Test suite()
    {
        return new TestSuite( UseCaseTest.class );
    }
    /**
     * Rigourous Test :-)
     */
    public void testApp()
    {
    	IParser national = Manager.get(IParserManager.class).getParser("National");
    	ISimulator simulatorAcq = Manager.get(ISimulatorManager.class).getSimulator("National Issuer");
    	ISimulator simulatorIss = Manager.get(ISimulatorManager.class).getSimulator("National Acquirer");
    	Socket socketAcq = new Socket("127.0.0.0", 8583, false, true, national, simulatorAcq, IAdapterManager.MLI_EXCLISIVE);
    	Socket socketIss = new Socket("127.0.0.0", 8583, true, false, national, simulatorIss, IAdapterManager.MLI_EXCLISIVE);

    	Message message = new Message("0200", national);
    	message.setValue(2, "1234567890123456");
    	message.setValue(3, "000000");
    	message.setValue(4, "000000012300");
    	message.setValue(11, "123456");
    	UseCase useCase = new UseCase(socketAcq, socketIss, message);
    	useCase.setValidator(new NullValidator(useCase));
    	Manager.get(IUseCaseExecutorManager.class).run(useCase); 
    }
}
