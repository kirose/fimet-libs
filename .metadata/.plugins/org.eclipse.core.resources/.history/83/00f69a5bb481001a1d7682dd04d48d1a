package com.fimet.core.usecase;

import com.fimet.core.IExecutorManager;
import com.fimet.core.Manager;
import com.fimet.core.iso8583.parser.Message;
import com.fimet.core.net.ISocket;
import com.fimet.core.validator.IValidator;
import com.fimet.core.validator.NullValidator;

public class TestBuilder {
	UseCase useCase;
	IExecutor executor;
	public TestBuilder(ISocket acquirer) {
		useCase = new UseCase();
		useCase.addConnection(acquirer);
		useCase.setMessage(new Message());
		useCase.getMessage().setParser(acquirer.getParser());
		executor = Manager.get(IExecutorManager.class).getSyncExecutor();
		
	}
	public TestBuilder mti(String mti) {
		useCase.getMessage().setMti(mti);
		return this;
	}
	public TestBuilder header(String header) {
		useCase.getMessage().setHeader(header);
		return this;
	}
	public TestBuilder message(Message message) {
		useCase.setMessage(message);
		return this;
	}
	public TestBuilder value(int idField, String value) {
		useCase.getMessage().setValue(idField, value);
		return this;
	}
	public TestBuilder remove(int idField) {
		useCase.getMessage().remove(idField);
		useCase.getMessage().remove(idField);
		return this;
	}
	public TestBuilder value(String idField, String value) {
		useCase.getMessage().setValue(idField, value);
		return this;
	}
	public TestBuilder remove(String idField) {
		useCase.getMessage().remove(idField);
		return this;
	}
	public TestBuilder validator(IValidator validator) {
		useCase.setValidator(validator != null ? validator : NullValidator.INSTANCE);
		return this;
	}
	public TestBuilder execute() {
		executor.execute(useCase);
		return this;
	}
}
