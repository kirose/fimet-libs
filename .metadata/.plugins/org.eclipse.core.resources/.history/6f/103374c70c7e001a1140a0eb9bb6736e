package com.fimet.core.net;

import com.fimet.core.iso8583.parser.Message;

public interface IMessengerListener {
	void onMessengerConnected(IMessenger messenger, byte[] message);
	void onMessengerConnecting(IMessenger messenger, byte[] message);
	void onMessengerDisconnected(IMessenger messenger, byte[] message);
	void onMessengerWriteResponse(IMessenger messenger, byte[] message);
	void onMessengerWriteRequest(IMessenger messenger, byte[] message);
	void onMessengerReadResponse(IMessenger messenger, byte[] message);
	void onMessengerReadRequest(IMessenger messenger, byte[] message);
	void onMessengerSimulateResponse(IMessenger messenger, Message response);
	void onMessengerSimulateRequest(IMessenger messenger, Message response);
}
