package com.fimet.net;


import java.io.IOException;

import java.net.Socket;

import com.fimet.core.iso8583.adapter.IAdapter;
import com.fimet.core.net.ISocketConnectionListener;
/**
 * @author Marco A. Salazar
 * @email marcoasb99@ciencias.unam.mx
 *
 */
public class AdaptedSocketServer extends AdaptedSocket {

	protected java.net.ServerSocket serverSocket;
	
	public AdaptedSocketServer(String address, int port, IAdapter adapter, ISocketConnectionListener listener) {
		super(address, port, adapter, listener);
	}
	
	@Override
	protected Socket newSocket() throws IOException {
		serverSocket = new java.net.ServerSocket(port);
		return socket = serverSocket.accept();
	}
	@Override
	void close() {
		if (socket != null)  {
			try {
				socket.close();
			} catch (Throwable e) {/*Activator.getInstance().warning("socket.close()", e);*/}
			socket = null;
		}
		if (serverSocket != null) {
			try {
				serverSocket.close();
			} catch (Throwable e) {/*Activator.getInstance().warning("serverSocket.close()", e);*/}
			serverSocket = null;
		}
	}
}
