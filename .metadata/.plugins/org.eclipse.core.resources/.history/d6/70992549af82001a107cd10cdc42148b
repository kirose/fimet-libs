package com.fimet.core.stress;

import java.io.File;
import java.io.FileInputStream;
import java.io.FileNotFoundException;
import java.io.IOException;
import java.io.InputStream;

import com.fimet.commons.FimetLogger;
import com.fimet.commons.exception.StressException;
import com.fimet.core.iso8583.adapter.IStreamAdapter;

public class StressFileReader extends Thread implements IReadable {
	private boolean alive;
	private InputStream in = null;
	private IStreamAdapter adapter;
	private IQueueable queueable;
	private byte[] message;
	public StressFileReader(IQueueable queueable, File stressFile, IStreamAdapter adapter) {
		this.queueable = queueable;
		this.adapter = adapter;
		try {
			in = new FileInputStream(stressFile);
		} catch (FileNotFoundException e) {
			throw new StressException(e);
		}
	}
	public void setQueueable(IQueueable queueable) {
		this.queueable = queueable;
	}
	@Override
	synchronized public void read() {
		this.notify();
	}
	@Override
	synchronized public boolean canRead() {
		return alive;
	}
	@Override
	synchronized public void startRead() {
		this.alive = true;
		this.start();
	}
	@Override
	synchronized public void stopRead() {
		if (currentThread().getState() == Thread.State.WAITING) {
			this.notify();
		}
		this.alive = false;
	}
	synchronized public void run() {
		try {
			while (alive) {
				message = adapter.readStream(in);
				if (message != null) {
					if (!queueable.canEnqueue()) {
						FimetLogger.debug(StressFileReader.class, "Stress File Reader Waiting");
						this.wait();
					}
					queueable.enqueue(message);
				} else {
					alive = false;
				}
			}
		} catch (Exception e) {
			FimetLogger.error("Thread error", e);
		}
		if (in != null) {
			try {
				in.close();
			} catch (IOException e) {}
		}
		FimetLogger.debug(StressFileReader.class, "Stress File Reader Finish");
	}
}
