package com.fimet.core.usecase.sync;

import java.util.concurrent.DelayQueue;
import java.util.concurrent.Delayed;
import java.util.concurrent.TimeUnit;

import com.fimet.commons.FimetLogger;
import com.fimet.core.usecase.IUseCase;

class UseCaseTimer extends Thread {
	private DelayQueue<Timer> queue = new DelayQueue<Timer>();
	private boolean alive = true;
	public UseCaseTimer() {
	}
	public void startTimer() {
		this.start();
	}
	public void stopTimer() {
		queue.clear();
		alive = false;
		this.notifyAll();
	}
	public void add(IUseCase useCase, IUseCaseTimerListener monitor) {
		queue.add(new Timer(useCase, monitor));
	}

	public void remove(IUseCase useCase) {
		if (queue != null && !queue.isEmpty()) {
			Timer match = null;
			for (Timer timer : queue) {
				if(timer == useCase) {
					match = timer;
					break;
				}
			}
			if (match != null)
				queue.remove(match);
		}
	}
	private class Timer implements Delayed {
		long timeout;
		IUseCase useCase;
		IUseCaseTimerListener monitor;
		private Timer(IUseCase useCase, IUseCaseTimerListener monitor) {
			this.useCase = useCase;
			this.monitor = monitor;
			this.timeout = System.currentTimeMillis() + useCase.getMaxExecutionTime();
		}
		@Override
		public int compareTo(Delayed o) {
			long other = ((Timer)o).timeout;
			return timeout < other ? -1 : (timeout == other ? 0 : 1);
		}
		@Override
		public long getDelay(TimeUnit unit) {
	        return unit.convert(timeout-System.currentTimeMillis(), TimeUnit.MILLISECONDS);
		}
	}
	public void run() {
		try {
			while (alive) {
				Timer next = queue.take();
				if (next != null)
					next.monitor.timeout(next.useCase);
			}
		} catch (Exception e) {
			FimetLogger.error("Thread error", e);
			run();
		}
	}
}
